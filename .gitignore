```gitignore
# =============================================================================
# Pamoja Chama
# Global .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------

node_modules/
frontend/node_modules/
backend/node_modules/

# -----------------------------------------------------------------------------
# Environment Variables
# -----------------------------------------------------------------------------

.env
.env.*
!.env.example

frontend/.env
frontend/.env.*

backend/.env
backend/.env.*

# -----------------------------------------------------------------------------
# Expo / React Native
# -----------------------------------------------------------------------------

.expo/
.expo-shared/

expo-env.d.ts

dist/
web-build/

# Metro
.metro-health-check*

# Expo generated
*.expo

# -----------------------------------------------------------------------------
# Android
# -----------------------------------------------------------------------------

android/

*.keystore
*.jks

# -----------------------------------------------------------------------------
# iOS
# -----------------------------------------------------------------------------

ios/

*.mobileprovision

# -----------------------------------------------------------------------------
# Backend Build
# -----------------------------------------------------------------------------

backend/dist/

coverage/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------

logs/

*.log

npm-debug.log*

yarn-debug.log*

yarn-error.log*

pnpm-debug.log*

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------

*.tsbuildinfo

# -----------------------------------------------------------------------------
# IDEs
# -----------------------------------------------------------------------------

.vscode/
.idea/

# -----------------------------------------------------------------------------
# Operating System
# -----------------------------------------------------------------------------

.DS_Store

Thumbs.db

desktop.ini

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------

*.tmp

*.temp

*.swp

*.swo

*.orig

# -----------------------------------------------------------------------------
# Certificates & Secrets
# -----------------------------------------------------------------------------

*.pem

*.key

*.p8

*.p12

*.crt

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------

.supabase/

# Local Supabase containers
.supabase/docker/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------

example/
```
